! #include <wchar.h>

? function
"wchar_t*" csvf_char_gen("char*" csvf);
? description: get unicode version of csvf file
? arg csvf: input file's name
? returns: generated unicode table

? function
"void" csvToCsvf("char*" inputName, "char*" outputName);
? description: Convert a csv file to a csvf file
? arg inputName: name of csv file
? arg outputName: name of csvf file

